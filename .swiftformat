# SwiftFormat configuration — https://github.com/nicklockwood/SwiftFormat
--swiftversion 5.9
--indent 4
--maxwidth 120
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--self remove
--importgrouping alpha
--commas inline
--trimwhitespace always
--emptybraces no-space
--exclude .build,build,dist,**/DolphinAsset.swift
